# =============================================================================
# Throttlr API — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Server
PORT=8000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://throttlr:throttlr_secret@localhost:5432/throttlr_db?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars
API_KEY_SALT=change_me_to_a_random_salt

# Logging
LOG_LEVEL=info
